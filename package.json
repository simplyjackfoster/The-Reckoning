{
  "name": "dead-reckoning",
  "private": true,
  "version": "0.1.0",
  "description": "Dead Reckoning - Apollo Guidance Computer interpretive execution environment",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run build && npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "markdownlint-cli2 *.md docs/**/*.md Luminary099/*.md --config .markdownlint.yml",
    "lint:fix": "markdownlint-cli2 *.md docs/**/*.md Luminary099/*.md --config .markdownlint.yml --fix",
    "guidance:extract": "bun scripts/extract-guidance.ts",
    "guidance:run": "bun scripts/run-guidance-slice.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "markdownlint-cli2": "^0.16.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
